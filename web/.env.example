# Variáveis públicas (frontend / browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nunca exponha service role no frontend.
# Use apenas em scripts server-side / ETL locais (nunca em componentes client).
# SUPABASE_SERVICE_ROLE_KEY=

# --- E2E (opcional, nunca versionar valores reais) ---
# E2E_BASE_URL=http://127.0.0.1:3000
# E2E_SUPABASE_PROJECT_REF=seu-projeto-de-teste
# E2E_ALLOW_DESTRUCTIVE_TESTS=false
# E2E_MASTER_EMAIL=
# E2E_MASTER_PASSWORD=
# E2E_ANALYST_EMAIL=
# E2E_ANALYST_PASSWORD=
# E2E_VIEWER_EMAIL=
# E2E_VIEWER_PASSWORD=
